[debug] [2025-10-07T02:18:45.324Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/agentqu-platform/rulesets {"name":"projects/agentqu-platform/rulesets/b5bd4333-4192-4bf9-84a4-0123bfb1005f","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    // Allow read access to activities for authenticated users\n    match /activities/{activity} {\n      allow read: if request.auth != null;\n    }\n\n    // Users can read/write their own data\n    match /users/{userId} {\n      allow read, write: if request.auth != null && request.auth.uid == userId;\n    }\n\n    // Cache can be read by authenticated users\n    match /cache/{document=**} {\n      allow read: if request.auth != null;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2025-10-07T02:18:45.341263Z","metadata":{"services":["cloud.firestore"]}}
